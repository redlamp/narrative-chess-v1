# Copy to .env.e2e.local and fill with hosted-dev test-only accounts.
# Do not use personal, admin, or production accounts.

E2E_PLAYER_A_EMAIL=player-a@example.com
E2E_PLAYER_A_PASSWORD=replace-with-dev-only-password
E2E_PLAYER_A_USERNAME=player_a

E2E_PLAYER_B_EMAIL=player-b@example.com
E2E_PLAYER_B_PASSWORD=replace-with-dev-only-password
E2E_PLAYER_B_USERNAME=player_b
